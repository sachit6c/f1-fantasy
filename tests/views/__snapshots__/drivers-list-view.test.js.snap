// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`DriversListView > snapshot > driver card structure matches snapshot 1`] = `"<div class="driver-card" style="cursor: pointer;"><div class="driver-photo-wrapper"><img src="data/images/drivers/max_verstappen.jpg" alt="Max Verstappen" class="driver-photo"></div><div class="driver-team-bar" style="background: rgb(54, 113, 198);"></div><div class="driver-info-section"><div class="driver-code" style="color: rgb(54, 113, 198);">VER</div><h2 class="driver-name">Max Verstappen</h2><div class="driver-team">Red Bull Racing</div><div class="driver-nationality">Dutch</div></div></div>"`;

exports[`DriversListView > snapshot > empty state matches snapshot 1`] = `
"<div class="empty-state">
      <div class="empty-state-icon"><svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="8" r="4"></circle>
          <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"></path>
        </svg></div>
      <h3>No drivers found</h3>
      <p>Driver data for this season hasn't been loaded yet.</p>
    </div>"
`;
