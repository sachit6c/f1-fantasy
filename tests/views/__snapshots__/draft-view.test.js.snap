// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`DraftView > snapshot > setup form matches snapshot 1`] = `"<div class="draft-setup"><div class="card"><h1 class="page-title">F1 Fantasy League</h1><form class="setup-form"><div class="form-group player1-input-group"><label>Player 1</label><input type="text" name="player1" placeholder="Enter Player 1 Name"></div><div class="form-group player2-input-group"><label>Player 2</label><input type="text" name="player2" placeholder="Enter Player 2 Name"></div><button class="btn-primary" type="submit" style="width: 100%; padding: 1rem; font-size: 1.125rem; margin-top: 1rem;">Start Draft</button></form></div></div>"`;
