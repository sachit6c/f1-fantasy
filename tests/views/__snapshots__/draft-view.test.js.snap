// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`DraftView > snapshot > setup form matches snapshot 1`] = `"<div class="draft-setup"><div class="card"><h1 class="page-title">F1 Fantasy League</h1><form class="setup-form"><div class="form-group player1-input-group"><label>Player 1</label><input type="text" name="player1" placeholder="Enter Player 1 Name"></div><div class="form-group player2-input-group"><label>Player 2</label><input type="text" name="player2" placeholder="Enter Player 2 Name"></div><div class="form-group"><label>Draft Type</label><select name="draftType"><option value="snake">Snake Draft</option><option value="linear">Linear Draft</option><option value="random_snake">Random Snake</option><option value="full_pick">Player 1 Picks All</option></select><div class="draft-type-description">Order reverses each round: A→B→B→A→A→B…</div></div><button class="btn-primary" type="submit" style="width: 100%; padding: 1rem; font-size: 1.125rem; margin-top: 1rem;">Start Draft</button></form></div></div>"`;
