// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`RaceDetailView > race not found > not-found state matches snapshot 1`] = `
"<div class="empty-state">
      <h2>Race Not Found</h2>
      <p>The race you're looking for doesn't exist.</p>
      <a href="#/calendar" class="btn-primary">Back to Calendar</a>
    </div>"
`;

exports[`RaceDetailView > snapshot > race detail header matches snapshot 1`] = `
"<div class="race-detail-header"><a class="back-link" href="#/calendar">← Back to Calendar</a><h1 class="page-title">Australian Grand Prix</h1><div class="race-subtitle">
      <span class="round-badge">Round 1</span>
      <span>Albert Park</span>
      <span>Melbourne, Australia</span>
    </div></div>"
`;
